! site-b-rtr - Site B edge router
! Interfaces: Gi0/0 = to wan-rtr, Gi0/1 = to site-b-sw (10.20.0.0/24 LAN); Gi0/2–3 unused
! BGP AS 64514 (Site B). Peer: wan-rtr (AS 64512)

hostname site-b-rtr

no ip domain lookup
ip cef

interface GigabitEthernet0/0
 description to wan-rtr WAN
 ip address 10.255.0.6 255.255.255.252
 no shutdown

interface GigabitEthernet0/1
 description to site-b-sw (site B LAN)
 ip address 10.20.0.1 255.255.255.0
 no shutdown

interface GigabitEthernet0/2
 description unused
 shutdown

interface GigabitEthernet0/3
 description unused
 shutdown

ip route 0.0.0.0 0.0.0.0 10.255.0.5

router bgp 64514
 bgp router-id 10.20.0.1
 network 10.20.0.0 mask 255.255.255.0
 neighbor 10.255.0.5 remote-as 64512
 no auto-summary

line con 0
 logging synchronous
line vty 0 4
 no login
 transport input ssh

end
