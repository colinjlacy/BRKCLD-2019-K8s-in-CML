! site-a-rtr - Site A edge router
! Interfaces: Gi0/0 = to wan-rtr, Gi0/1 = to k8s-a-cp, Gi0/2 = to k8s-a-w1, Gi0/3 = to k8s-a-w2
! BGP AS 64513 (Site A). Peer: wan-rtr (AS 64512)

hostname site-a-rtr

! Add before 'login local': username <youruser> privilege 15 secret <yourpassword>
no ip domain lookup
ip cef

interface GigabitEthernet0/0
 description to wan-rtr WAN
 ip address 10.255.0.2 255.255.255.252
 no shutdown

interface GigabitEthernet0/1
 description to k8s-a-cp
 ip address 10.10.0.1 255.255.255.252
 no shutdown

interface GigabitEthernet0/2
 description to k8s-a-w1
 ip address 10.10.0.5 255.255.255.252
 no shutdown

interface GigabitEthernet0/3
 description to k8s-a-w2
 ip address 10.10.0.9 255.255.255.252
 no shutdown

router bgp 64513
 bgp router-id 10.10.0.1
 network 10.10.0.0 mask 255.255.255.0
 neighbor 10.255.0.1 remote-as 64512
 no auto-summary

line con 0
 logging synchronous
line vty 0 4
 login local
 transport input ssh

end
