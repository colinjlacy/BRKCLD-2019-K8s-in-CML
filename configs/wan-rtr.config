! wan-rtr - WAN router (single default exit for all Linux nodes)
! Interfaces: Gi0/0 = shared services, Gi0/1 = to site-a-rtr, Gi0/2 = to site-b-rtr, Gi0/3 = external/Internet
! BGP AS 64512 (WAN). Peers: site-a-rtr (AS 64513), site-b-rtr (AS 64514). Originates default to both.

hostname wan-rtr

! Add before 'login local': username <youruser> privilege 15 secret <yourpassword>
no ip domain lookup
ip cef

interface GigabitEthernet0/0
 description to jump-1 shared services
 ip address 10.30.0.1 255.255.255.0
 no shutdown

interface GigabitEthernet0/1
 description to site-a-rtr WAN
 ip address 10.255.0.1 255.255.255.252
 no shutdown

interface GigabitEthernet0/2
 description to site-b-rtr WAN
 ip address 10.255.0.5 255.255.255.252
 no shutdown

interface GigabitEthernet0/3
 description to external/Internet transit
 ip address 192.0.2.1 255.255.255.0
 no shutdown

ip route 0.0.0.0 0.0.0.0 192.0.2.2

router bgp 64512
 bgp router-id 10.255.0.1
 network 10.30.0.0 mask 255.255.255.0
 default-information originate
 neighbor 10.255.0.2 remote-as 64513
 neighbor 10.255.0.6 remote-as 64514
 no auto-summary

line con 0
 logging synchronous
line vty 0 4
 login local
 transport input ssh

end
